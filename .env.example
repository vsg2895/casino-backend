APP_NAME="Casino Affiliate API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=casino_affiliate
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail routing ──────────────────────────────────────────────────────────
# The platform sends two kinds of mail through two transports:
#
#   • ADMIN mail — "Send test" buttons (subscription + verify + promotion) AND
#     real promotion campaigns/scheduler
#       → your own SMTP, configured by the MAIL_* vars below (MAIL_ADMIN_MAILER).
#   • PUBLIC verification mail — when a visitor subscribes on a public site
#       → SendGrid native Web API (NOT SMTP), via SENDGRID_API_KEY (MAIL_PUBLIC_MAILER).
#
# Default mailer used by admin test sends. Set to "smtp" to use the SMTP config
# below; "log" writes to storage/logs for local development.
MAIL_MAILER=log

# SMTP for admin "Send test" emails (your provider: Mailtrap, MailHog, Gmail, …).
# DELIVERABILITY: the sender domain must match the domain your SMTP is authorised
# for, or receivers silently drop the mail (SPF/DKIM/DMARC). Keep MAIL_FROM_ADDRESS
# and SENDGRID_FROM_DOMAIN (the per-site template sender domain) on that SAME domain
# as MAIL_USERNAME. For implicit-TLS providers on port 465, set MAIL_SCHEME=smtps.
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Transport selection (optional — these are the defaults).
MAIL_ADMIN_MAILER=smtp            # admin tests + promotion campaigns → SMTP
MAIL_PUBLIC_MAILER=sendgrid       # public verification emails → SendGrid

# SendGrid — used ONLY for public verification emails (visitor subscribes). Sent
# via the native SendGrid Web API (symfony/sendgrid-mailer) using this key — no
# SMTP. Replace the placeholder with your real key for public emails to deliver.
SENDGRID_API_KEY=SG.fake-key-replace-me-0000000000000000000000
# Advisory only: suggested sending domain shown as a hint in the admin email editor.
SENDGRID_FROM_DOMAIN=example.com

# Forced verified sender for ALL public verification emails, regardless of which
# site the visitor subscribed on. Set to the address on the domain authenticated
# in SendGrid (e.g. noreply@winpalack.com). Display name stays per-site, and the
# email's body links still point at the subscribing site's own real domain.
# Leave EMPTY (once each domain is authenticated) for per-site From domains.
MAIL_PUBLIC_FROM_ADDRESS=noreply@winpalack.com

# Public site URLs baked into email links (verify / unsubscribe). Real https
# domains by default (Site::frontendBaseUrl → https://{site domain}). Uncomment to
# repoint ONE site at a local dev server without affecting the others.
#SITE_URL_IDEVAFFILIATION=http://localhost:3000
#SITE_URL_WINPALACK=http://localhost:3001

# Sanctum / CORS — добавьте новые домены сайтов через запятую при расширении
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SESSION_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173

# Next.js revalidation — список URL всех публичных сайтов через запятую
# При добавлении нового сайта: добавьте сюда его URL
REVALIDATE_SECRET=
NEXT_REVALIDATE_URLS="http://localhost:3000"
