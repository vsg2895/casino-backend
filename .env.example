APP_NAME="Casino Affiliate API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=casino_affiliate
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail routing ──────────────────────────────────────────────────────────
# The platform sends two kinds of mail through two transports:
#
#   • Admin "Send test" buttons (subscription + promotion emails)
#       → your own SMTP, configured by the MAIL_* vars below (test_mailer).
#   • Real confirmation emails when a visitor subscribes on a public site
#       → SendGrid native Web API (NOT SMTP), via SENDGRID_API_KEY (newsletter_mailer).
#
# Default mailer used by admin test sends. Set to "smtp" to use the SMTP config
# below; "log" writes to storage/logs for local development.
MAIL_MAILER=log

# SMTP for admin "Send test" emails (your provider: Mailtrap, MailHog, Gmail, …).
# DELIVERABILITY: the sender domain must match the domain your SMTP is authorised
# for, or receivers silently drop the mail (SPF/DKIM/DMARC). Keep MAIL_FROM_ADDRESS
# and SENDGRID_FROM_DOMAIN (the per-site template sender domain) on that SAME domain
# as MAIL_USERNAME. For implicit-TLS providers on port 465, set MAIL_SCHEME=smtps.
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional overrides — leave unset to use the defaults described above.
# MAIL_TEST_MAILER=smtp          # transport for admin "Send test" actions
# MAIL_NEWSLETTER_MAILER=sendgrid # transport for public subscription emails

# SendGrid — public subscription/newsletter emails for ALL sites, sent via the
# native SendGrid Web API (symfony/sendgrid-mailer) using this key directly — no
# SMTP. Replace the placeholder with your real key for public emails to deliver.
SENDGRID_API_KEY=SG.fake-key-replace-me-0000000000000000000000
# Advisory only: suggested sending domain shown as a hint in the admin email editor.
SENDGRID_FROM_DOMAIN=example.com

# Unsubscribe links — opaque per-stream token only, no personal data in the URL.
# Optional override so links point at localhost while developing/testing the
# unsubscribe flow. Leave empty in production (links use each site's own domain).
UNSUBSCRIBE_BASE_URL=http://localhost:3000

# Sanctum / CORS — добавьте новые домены сайтов через запятую при расширении
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SESSION_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173

# Next.js revalidation — список URL всех публичных сайтов через запятую
# При добавлении нового сайта: добавьте сюда его URL
REVALIDATE_SECRET=
NEXT_REVALIDATE_URLS="http://localhost:3000"
