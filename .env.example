APP_NAME="Casino Affiliate API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=casino_affiliate
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# SendGrid — subscription/newsletter emails for ALL sites via one API key.
# username is the literal "apikey"; password is the SendGrid API key below.
SENDGRID_API_KEY=SG.fake-key-replace-me-0000000000000000000000
SENDGRID_FROM_DOMAIN=example.com

# Sanctum / CORS — добавьте новые домены сайтов через запятую при расширении
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
SESSION_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173

# Next.js revalidation — список URL всех публичных сайтов через запятую
# При добавлении нового сайта: добавьте сюда его URL
REVALIDATE_SECRET=
NEXT_REVALIDATE_URLS="http://localhost:3000"
